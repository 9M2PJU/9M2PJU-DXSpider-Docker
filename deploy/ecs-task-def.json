{
    "family": "dxspider",
    "networkMode": "awsvpc",
    "containerDefinitions": [
        {
            "name": "dxspider",
            "image": "ghcr.io/9m2pju/9m2pju-dxspider-docker:main",
            "portMappings": [
                {
                    "containerPort": 7300,
                    "hostPort": 7300,
                    "protocol": "tcp"
                },
                {
                    "containerPort": 8080,
                    "hostPort": 8080,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "environment": [
                { "name": "CLUSTER_CALLSIGN", "value": "N0CALL-2" },
                { "name": "CLUSTER_SYSOP_CALLSIGN", "value": "N0CALL" }
            ],
            "mountPoints": [
                {
                    "sourceVolume": "spider-data",
                    "containerPath": "/spider/local_data",
                    "readOnly": false
                }
            ]
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "volumes": [
        {
            "name": "spider-data",
            "efsVolumeConfiguration": {
                "fileSystemId": "fs-xxxxxx",
                "rootDirectory": "/"
            }
        }
    ]
}
